# Streamlit secrets template for Engineering Cockpit
#
# LOCAL DEVELOPMENT:
#   Copy this file to .streamlit/secrets.toml and fill in your values.
#   (secrets.toml is gitignored)
#
# STREAMLIT COMMUNITY CLOUD:
#   Paste these key=value pairs directly into the Streamlit Cloud
#   dashboard under App Settings → Secrets.
#
# ALTERNATIVE: set these as shell environment variables or in .env
# The app reads: os.environ → st.secrets → .env files (in that priority order).

# ── Required: Jira integration ────────────────────────────────────────────────
JIRA_BASE_URL    = "https://your-org.atlassian.net"
JIRA_EMAIL       = "your-email@example.com"
JIRA_API_TOKEN   = "your-atlassian-api-token"
JIRA_PROJECT_KEY = "YOUR_PROJECT_KEY"

# ── Optional: AI advisory layer ───────────────────────────────────────────────
# COCKPIT_AI_ENABLED = "true"
# ANTHROPIC_API_KEY  = "sk-ant-..."

# ── Optional: custom Jira field IDs (auto-detected if omitted) ────────────────
# SPRINT_FIELD_ID       = "customfield_10020"
# STORY_POINTS_FIELD_ID = "customfield_10033"

# ── Optional: data path override ─────────────────────────────────────────────
# COCKPIT_DATA_DIR = "/tmp/cockpit-data"   # useful on ephemeral cloud filesystems
