# ADAPT Engineering Cockpit — required env vars
# Copy to .env and fill in real values

# Jira Cloud (required for live data)
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=your_atlassian_api_token
JIRA_PROJECT_KEY=NAI

# Optional: override custom field IDs if auto-detect fails
# SPRINT_FIELD_ID=customfield_10020
# STORY_POINTS_FIELD_ID=customfield_10016

# AI advisory (optional)
COCKPIT_AI_ENABLED=false
ANTHROPIC_API_KEY=

# Data directory (default: ./data relative to repo root)
# COCKPIT_DATA_DIR=data
